# 1. ベースモデルの指定（自分で量子化したGGUFファイルを指定）
# FROM ./gemma-4-E4B-it-IQ4_XS.gguf
FROM gemma4:e4b

# 2. パラメータ設定
# num_ctx: コンテキストサイズ。画面の履歴を覚えるために少し多めに設定
PARAMETER num_ctx 2048
# temperature: 1.0に近いほど創造的、低いほど正確。実況なら 0.7 くらいが面白い
PARAMETER temperature 0.7

# 思考（Reasoning）プロセスを少し抑制するための設定（もし効けば）
PARAMETER repeat_penalty 1.1
PARAMETER top_p 0.9

SYSTEM """

"""

# 4. 対話フォーマット（Gemma 4 標準のテンプレート）
TEMPLATE "{{ if .System }}<start_of_turn>system
{{ .System }}<end_of_turn>
{{ end }}{{ if .Prompt }}<start_of_turn>user
{{ .Prompt }}<end_of_turn>
{{ end }}<start_of_turn>model
{{ .Response }}<end_of_turn>"
