{
  "name": "live-vision-narrator",
  "scripts": {
    "check": "pnpm lint:check && pnpm fmt:check && pnpm test && pnpm build",
    "fix": "pnpm lint:fix && pnpm fmt:fix",
    "dev:go": "go -C src-go run .",
    "run:go": "pnpm build:go && powershell -Command \"& './bin/narrator_engine.exe'\"",
    "setup:tools": "go install github.com/golangci/golangci-lint/cmd/golangci-lint && go install mvdan.cc/gofumpt",

    "test": "run-p test:go",
    "test:go": "go -C src-go test ./...",

    "lint:check": "run-p lint:go:check",
    "lint:fix": "run-p lint:go:fix",
    "lint:go:check": "golangci-lint run --config .golangci.yml ./src-go/...",
    "lint:go:fix": "golangci-lint run --config .golangci.yml --fix ./src-go/...",

    "fmt:check": "echo 'no fmt tasks configured'",
    "fmt:fix": "echo 'no fmt tasks configured'",

    "build": "run-p build:go",
    "build:go": "go -C src-go build -o ../bin/narrator_engine.exe",

    "get:go": "go -C src-go get ./...",
    "tidy:go": "go -C src-go mod tidy",
    "models:create": "ollama create my-narrator -f ./models/Modelfile",
    "clean": "npx rimraf bin/*",

    "go:gen-tests": "gotests -all -w src-go/main.go"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
